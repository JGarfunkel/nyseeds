    "cmdk": "^1.1.1",
    "connect-pg-simple": "^10.0.0",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.39.1",
    "drizzle-zod": "^0.7.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "fs-extra": "^11.3.1",
    "leaflet": "^1.9.4",
    "memorystore": "^1.6.7",
    "nanoid": "^5.1.5",
    "openai": "^5.12.2",
    "passport": "^0.7.0",
